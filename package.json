{
  "name": "stackorbitai-meeting-copilot",
  "version": "1.0.0",
  "description": "StackOrbitAI Meeting Intelligence & AI Copilot",
  "main": "dist/main/index.js",
  "author": "StackOrbitAI <support@stackorbitai.com>",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsup src/main/index.ts src/main/preload.ts --out-dir dist/main --format cjs --external electron",
    "build": "npm run build:renderer && npm run build:main",
    "test": "tsup src/main/test.ts --out-dir dist/test --format cjs --external electron && node dist/test/test.js",
    "package": "npm run build && electron-builder --win --mac --linux",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.stackorbitai.meeting-copilot",
    "productName": "StackOrbitAI Meeting Intelligence & AI Copilot",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StackOrbitAI Meeting Intelligence & AI Copilot",
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    }
  }
}
